# LINE LIFF 整合 — 從 https://developers.line.biz/console/ 取得
# 沒填也可用普通網頁模式跑，只是不會走 LINE 登入 / 分享 flex 訊息
NEXT_PUBLIC_LIFF_ID=
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Supabase (填入才會啟用後端；dormant 時用 localStorage) ---
# 1. 到 https://supabase.com/ 建專案
# 2. SQL editor 跑 supabase/migrations/0001_init.sql + seed.sql
# 3. Settings → API 拿 URL + anon key 填這裡
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
